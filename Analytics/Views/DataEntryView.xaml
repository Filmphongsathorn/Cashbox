<UserControl
    x:Class="CashboxAnalyzer.Analytics.Views.DataEntryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CashboxAnalyzer.Analytics.ViewModels"
    mc:Ignorable="d"
    Background="#F8FAFC"
    FontFamily="Segoe UI"
    d:DataContext="{d:DesignInstance vm:DataEntryViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="16"/>
            <Setter Property="Padding"         Value="24"/>
            <Setter Property="Effect">
                <Setter.Value><DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.03" Color="#0F172A"/></Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0A2540"/>
            <Setter Property="Margin"     Value="0,15,0,5"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Height"          Value="60"/>
            <Setter Property="Padding"         Value="15,0"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="Foreground"      Value="#0F172A"/>
            <Setter Property="Background"      Value="#F8FAFC"/>
            <Setter Property="BorderBrush"     Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height"      Value="60"/>
            <Setter Property="Padding"     Value="15,0"/>
            <Setter Property="FontSize"    Value="20"/>
            <Setter Property="Foreground"  Value="#0F172A"/>
            <Setter Property="Background"  Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DatePicker -->
        <Style x:Key="FormDate" TargetType="DatePicker">
            <Setter Property="Height"      Value="60"/>
            <Setter Property="FontSize"    Value="20"/>
            <Setter Property="Foreground"  Value="#0F172A"/>
            <Setter Property="Background"  Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="24"/>
            <Setter Property="Height"          Value="70"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"      Value="#EF4444"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="24"/>
            <Setter Property="Height"          Value="70"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem -->
        <Style x:Key="NavTab" TargetType="TabItem">
            <Setter Property="FontSize"   Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="40,20"/>
            <Setter Property="Foreground" Value="#5B7A9D"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,3" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#1E88E5"/>
                                <Setter Property="Foreground" Value="#0A2540"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0A2540"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="MiniGrid" TargetType="DataGrid">
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#BFDBFE"/>
            <Setter Property="AlternatingRowBackground"  Value="#F0F9FF"/>
            <Setter Property="RowBackground"       Value="Transparent"/>
            <Setter Property="HeadersVisibility"   Value="Column"/>
            <Setter Property="CanUserAddRows"      Value="False"/>
            <Setter Property="IsReadOnly"          Value="True"/>
            <Setter Property="FontSize"            Value="18"/>
            <Setter Property="RowHeight"           Value="50"/>
            <Setter Property="Foreground"          Value="#0A2540"/>
            <Setter Property="SelectionMode"       Value="Single"/>
        </Style>
        <Style x:Key="MiniGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#DBEAFE"/>
            <Setter Property="Foreground"   Value="#0A2540"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="18"/>
            <Setter Property="Padding"      Value="15,12"/>
            <Setter Property="BorderBrush"  Value="#BAE6FD"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Loading overlay -->
        <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                Background="#88E0F2FE" Panel.ZIndex="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="180" Height="4" Foreground="#1E88E5"/>
                <TextBlock Text="กำลังบันทึก…" FontSize="13" FontWeight="SemiBold"
                           Foreground="#0A2540" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <StackPanel>

                <!-- Page header -->
                <TextBlock Text="บันทึกรายรับ / รายจ่าย"
                           FontSize="22" FontWeight="Bold" Foreground="#0A2540"/>

                <!-- Status bar -->
                <Border CornerRadius="8" Padding="12,8"
                        Visibility="{Binding StatusMessage,
                            Converter={StaticResource BoolToVis},
                            ConverterParameter=NotEmpty}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#DCFCE7"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- ════ TAB CONTROL ════════════════════════════════ -->
                <TabControl Background="Transparent" BorderThickness="0"
                            SelectedIndex="{Binding SelectedTab}">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Background" Value="White"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- ══ TAB 1: รายรับ ════════════════════════════ -->
                    <TabItem Header="💰  บันทึกรายรับ" Style="{StaticResource NavTab}">
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="6*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Form -->
                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="กรอกข้อมูลรายรับ" FontSize="18"
                                               FontWeight="Bold" Foreground="#0A2540"/>
                                    <Border Height="1" Background="#BAE6FD" Margin="0,15,0,5"/>

                                    <TextBlock Text="วันที่" Style="{StaticResource FormLabel}"/>
                                    <DatePicker SelectedDate="{Binding RevenueDate}"
                                                Style="{StaticResource FormDate}"/>

                                    <TextBlock Text="หมวดรายรับ" Style="{StaticResource FormLabel}"/>
                                    <ComboBox ItemsSource="{Binding RevenueCategories}"
                                              SelectedValue="{Binding RevenueSource}"
                                              Style="{StaticResource FormCombo}"
                                              IsEditable="False"/>

                                    <TextBlock Text="จำนวนเงิน (บาท)" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding RevenueAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>

                                    <TextBlock Text="คำอธิบาย (รายได้จากอะไร)" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding RevenueNote, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"
                                             AcceptsReturn="False"/>

                                    <Button Content="💾  บันทึกรายรับ"
                                            Style="{StaticResource PrimaryBtn}"
                                            Margin="0,16,0,0"
                                            Command="{Binding SaveRevenueCommand}"/>
                                </StackPanel>
                            </Border>

                            <!-- Recent Revenue List -->
                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="รายรับล่าสุด 10 รายการ" FontSize="14" FontWeight="Bold" Foreground="#0A2540" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="150" HorizontalAlignment="Right" Style="{StaticResource FormBox}" ToolTip="พิมพ์เพื่อค้นหา..." />
                                    </Grid>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding RecentRevenues}"
                                              Style="{StaticResource MiniGrid}"
                                              ColumnHeaderStyle="{StaticResource MiniGridHeader}"
                                              AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="วันที่"   Binding="{Binding Date}"          Width="90"/>
                                            <DataGridTextColumn Header="หมวด"    Binding="{Binding RevenueSource}"  Width="100"/>
                                            <DataGridTemplateColumn Header="จำนวน (฿)" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TotalCashAmount, StringFormat=N2}"
                                                                   Foreground="#16A34A" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="คำอธิบาย" Binding="{Binding Note}" Width="*"/>
                                            <DataGridTemplateColumn Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="ลบ" Command="{Binding DataContext.DeleteRevenueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#EF5350" Foreground="White" BorderThickness="0" Cursor="Hand" Height="24" FontSize="11">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ══ TAB 2: รายจ่าย ═══════════════════════════ -->
                    <TabItem Header="📤  บันทึกรายจ่าย" Style="{StaticResource NavTab}">
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="6*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Form -->
                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="กรอกข้อมูลรายจ่าย" FontSize="18"
                                               FontWeight="Bold" Foreground="#0A2540"/>
                                    <Border Height="1" Background="#BAE6FD" Margin="0,15,0,5"/>

                                    <TextBlock Text="วันที่" Style="{StaticResource FormLabel}"/>
                                    <DatePicker SelectedDate="{Binding ExpenseDate}"
                                                Style="{StaticResource FormDate}"/>

                                    <TextBlock Text="หมวดรายจ่าย" Style="{StaticResource FormLabel}"/>
                                    <ComboBox ItemsSource="{Binding ExpenseCategories}"
                                              SelectedValue="{Binding ExpenseCategory}"
                                              Style="{StaticResource FormCombo}"
                                              IsEditable="False"/>

                                    <TextBlock Text="จำนวนเงิน (บาท)" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding ExpenseAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>

                                    <TextBlock Text="คำอธิบาย (รายจ่ายจากค่าอะไร)" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding ExpenseNote, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>

                                    <Button Content="💾  บันทึกรายจ่าย"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="#EF5350"
                                            Margin="0,16,0,0"
                                            Command="{Binding SaveExpenseCommand}"/>
                                </StackPanel>
                            </Border>

                            <!-- Recent Expense List -->
                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="รายจ่ายล่าสุด 10 รายการ" FontSize="14" FontWeight="Bold" Foreground="#0A2540" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="150" HorizontalAlignment="Right" Style="{StaticResource FormBox}" ToolTip="พิมพ์เพื่อค้นหา..." />
                                    </Grid>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding RecentExpenses}"
                                              Style="{StaticResource MiniGrid}"
                                              ColumnHeaderStyle="{StaticResource MiniGridHeader}"
                                              AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="วันที่"   Binding="{Binding Date}"     Width="90"/>
                                            <DataGridTextColumn Header="หมวด"    Binding="{Binding Category}" Width="100"/>
                                            <DataGridTemplateColumn Header="จำนวน (฿)" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Amount, StringFormat=N2}"
                                                                   Foreground="#DC2626" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="คำอธิบาย" Binding="{Binding Note}" Width="*"/>
                                            <DataGridTemplateColumn Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="ลบ" Command="{Binding DataContext.DeleteExpenseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#EF5350" Foreground="White" BorderThickness="0" Cursor="Hand" Height="24" FontSize="11">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ══ TAB 3: จัดการหมวดหมู่ ════════════════════ -->
                    <TabItem Header="⚙️  จัดการหมวดหมู่" Style="{StaticResource NavTab}">
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Revenue Categories -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="หมวดหมู่รายรับ" FontSize="18"
                                               FontWeight="Bold" Foreground="#0A2540"/>
                                    <Border Height="1" Background="#BAE6FD" Margin="0,10,0,12"/>

                                    <!-- Add new -->
                                    <TextBlock Text="เพิ่มหมวดใหม่" Style="{StaticResource FormLabel}"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewRevenueCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FormBox}"
                                                 x:Name="NewRevCatBox"/>
                                        <Button Grid.Column="2" Content="+ เพิ่ม"
                                                Style="{StaticResource PrimaryBtn}"
                                                Width="80"
                                                Command="{Binding AddRevenueCategoryCommand}"/>
                                    </Grid>

                                    <!-- Delete existing -->
                                    <TextBlock Text="ลบหมวดที่มีอยู่" Style="{StaticResource FormLabel}"
                                               Margin="0,14,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding RevenueCategories}"
                                                  SelectedValue="{Binding SelectedRevCatToDelete}"
                                                  Style="{StaticResource FormCombo}"/>
                                        <Button Grid.Column="2" Content="ลบ"
                                                Style="{StaticResource DangerBtn}"
                                                Width="64"
                                                Command="{Binding DeleteRevenueCategoryCommand}"/>
                                    </Grid>

                                    <!-- List -->
                                    <TextBlock Text="รายการปัจจุบัน" Style="{StaticResource FormLabel}"
                                               Margin="0,14,0,4"/>
                                    <ItemsControl ItemsSource="{Binding RevenueCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F0F9FF" CornerRadius="6"
                                                        Padding="10,6" Margin="0,2">
                                                    <TextBlock Text="{Binding}" FontSize="13"
                                                               Foreground="#0A2540"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Expense Categories -->
                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="หมวดหมู่รายจ่าย" FontSize="18"
                                               FontWeight="Bold" Foreground="#0A2540"/>
                                    <Border Height="1" Background="#BAE6FD" Margin="0,10,0,12"/>

                                    <TextBlock Text="เพิ่มหมวดใหม่" Style="{StaticResource FormLabel}"
                                               Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewExpenseCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FormBox}"/>
                                        <Button Grid.Column="2" Content="+ เพิ่ม"
                                                Style="{StaticResource PrimaryBtn}"
                                                Width="80"
                                                Command="{Binding AddExpenseCategoryCommand}"/>
                                    </Grid>

                                    <TextBlock Text="ลบหมวดที่มีอยู่" Style="{StaticResource FormLabel}"
                                               Margin="0,14,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding ExpenseCategories}"
                                                  SelectedValue="{Binding SelectedExpCatToDelete}"
                                                  Style="{StaticResource FormCombo}"/>
                                        <Button Grid.Column="2" Content="ลบ"
                                                Style="{StaticResource DangerBtn}"
                                                Width="64"
                                                Command="{Binding DeleteExpenseCategoryCommand}"/>
                                    </Grid>

                                    <TextBlock Text="รายการปัจจุบัน" Style="{StaticResource FormLabel}"
                                               Margin="0,14,0,4"/>
                                    <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF5F5" CornerRadius="6"
                                                        Padding="10,6" Margin="0,2">
                                                    <TextBlock Text="{Binding}" FontSize="13"
                                                               Foreground="#0A2540"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Database Management -->
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="จัดการฐานข้อมูล" FontSize="15" FontWeight="Bold" Foreground="#0A2540"/>
                                    <Border Height="1" Background="#BAE6FD" Margin="0,10,0,12"/>
                                    <TextBlock Text="สำรองข้อมูลเพื่อป้องกันข้อมูลสูญหาย หรือกู้คืนจากไฟล์ที่เคยสำรองไว้" Style="{StaticResource FormLabel}" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="💾 สำรองข้อมูล" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,10,0" Background="#107C41" Width="180"/>
                                        <Button Content="📂 กู้คืนข้อมูล" Command="{Binding RestoreDatabaseCommand}" Style="{StaticResource PrimaryBtn}" Background="#F59E0B" Width="180"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
